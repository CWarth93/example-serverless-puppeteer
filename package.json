    "micro-cors": "^0.1.1",
    "moment": "^2.29.1",
    "next": "10.0.0",
    "prettier": "^2.0.2",
    "puppeteer-core": "10.1.0",
    "react": "^17.0.2",
    "react-dom": "^17.0.2"
  },
  "devDependencies": {
    "puppeteer": "10.1.0"
  }
