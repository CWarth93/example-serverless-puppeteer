{
  "name": "example-serverless-puppeteer",
  "version": "0.1.0",
  "author": "kiljimintaru",
  "scripts": {
    "setup": "cross-env PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=1 npm install",
    "style": "prettier --single-quote --use-tabs --arrow-parens always --quote-props consistent --print-width 160 --write **/*.{ts,js,css,html}",
    "run": "node --openssl-legacy-provider node_modules/next/dist/bin/next dev -p 3030",
    "publish": "lt --port 3030",
    "vercel-build": "node --openssl-legacy-provider node_modules/next/dist/bin/next build"
  },
  "dependencies": {
    "@serverless-chrome/lambda": "^1.0.0-57.2",
    "@sparticuz/chromium": "^131.0.1",
    "chrome-launcher": "^0.15.0",
    "dotenv": "^8.2.0",
    "localtunnel": "^2.0.2",
    "micro-cors": "^0.1.1",
    "moment": "^2.29.1",
    "next": "10.0.0",
    "prettier": "^2.0.2",
    "puppeteer-core": "^23.10.4",
    "react": "^17.0.2",
    "react-dom": "^17.0.2"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "puppeteer": "^21.6.0"
  }
}
